# TalentFlow Environment Variables Example

# --- Supabase Configuration ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Services Configuration ---
# Browser-facing URL used by host browser requests in Docker dev.
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# Container-to-container URL used by frontend server routes and workers in Docker dev.
# If you run the app outside Docker, switch this back to http://localhost:8000.
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_INTERNAL_TOKEN=cv-import-local-token
CV_IMPORTS_INTERNAL_TOKEN=cv-import-local-token
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
PADDLE_OCR_SYNC_URL=https://c2yeg2d9zfnduff0.aistudio-app.com/layout-parsing
PADDLE_OCR_SYNC_TOKEN=your_sync_token
PADDLE_OCR_ASYNC_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLE_OCR_ASYNC_TOKEN=your_async_token
PADDLE_OCR_ASYNC_MODEL=PaddleOCR-VL-1.5

# Optional if you keep Ollama running on the host while using Docker Compose dev.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key

# --- Email Configuration (SMTP) ---
# For Gmail, use an "App Password"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=TalentFlow <your_email@gmail.com>

# --- Media Upload Configuration (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional when using unsigned upload presets
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# --- App Settings ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
